---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Insights">
	<main class="max-w-4xl mx-auto px-4 py-24">
		<header class="mb-16">
			<h1 class="text-5xl font-black mb-4">Strategic <span class="text-gradient">Insights</span></h1>
			<p class="text-xl text-gray-400">Technical outcomes, serverless patterns, and maker culture experiments.</p>
		</header>

		<div class="space-y-12">
			{posts.map((post) => (
				<article class="group">
					<a href={`/blog/${post.slug}`} class="block space-y-4">
						<div class="flex items-center gap-4 text-sm text-solar-orange font-mono uppercase tracking-widest">
							<time datetime={post.data.pubDate.toISOString()}>
								{post.data.pubDate.toLocaleDateString('en-us', {
									year: 'numeric',
									month: 'short',
									day: 'numeric',
								})}
							</time>
							<span>•</span>
							<span>{post.data.category || 'General'}</span>
						</div>
						<h2 class="text-3xl font-bold group-hover:text-solar-orange transition-colors">
							{post.data.title}
						</h2>
						<p class="text-gray-400 leading-relaxed max-w-2xl">
							{post.data.description}
						</p>
					</a>
				</article>
			))}
		</div>
	</main>
</Layout>
